    <script src="https://unpkg.com/swagger-ui-dist@5.10.5/swagger-ui-bundle.js"></script>
    <script src="https://unpkg.com/swagger-ui-dist@5.10.5/swagger-ui-standalone-preset.js"></script>
    
    <script>
        mermaid.initialize({ 
            startOnLoad: true,
            theme: 'default',
            themeVariables: {
                primaryColor: '#E33814',
                primaryTextColor: '#262626',
                primaryBorderColor: '#D4D4D4',
                lineColor: '#525252',
                secondaryColor: '#10B981',
                tertiaryColor: '#F5F5F5'
            }
        });

        window.onload = function() {
            const ui = SwaggerUIBundle({
                url: "openapi.yaml",
                dom_id: '#swagger-ui',
                deepLinking: true,
                presets: [
                    SwaggerUIBundle.presets.apis,
                    SwaggerUIStandalonePreset
                ],
                plugins: [
                    SwaggerUIBundle.plugins.DownloadUrl
                ],
                layout: "BaseLayout",
                defaultModelsExpandDepth: 1,
                defaultModelExpandDepth: 1,
                docExpansion: "list",
                filter: true,
                tryItOutEnabled: true,
                persistAuthorization: true,
                onComplete: function() {
                    setTimeout(() => {
                        const allCodeBlocks = document.querySelectorAll('.swagger-ui pre code, .swagger-ui pre');
                        console.log('Checking', allCodeBlocks.length, 'code blocks');
                        
                        let mermaidCount = 0;
                        allCodeBlocks.forEach((block, index) => {
                            const text = block.textContent.trim();
                            
                            if (text.includes('sequenceDiagram') || text.includes('graph') || text.includes('flowchart')) {
                                console.log('Found Mermaid diagram:', text.substring(0, 100));
                                mermaidCount++;
                                
                                const preElement = block.tagName === 'PRE' ? block : block.closest('pre');
                                if (preElement && !preElement.querySelector('.mermaid-diagram')) {
                                    const codeElement = preElement.querySelector('code');
                                    if (codeElement) {
                                        codeElement.style.display = 'none';
                                    }
                                    
                                    const container = document.createElement('div');
                                    container.className = 'mermaid-diagram';
                                    container.id = 'mermaid-diagram-' + index;
                                    
                                    try {
                                        mermaid.render('mermaid-svg-' + index, text).then(result => {
                                            container.innerHTML = result.svg;
                                            preElement.appendChild(container);
                                            console.log('Mermaid rendered successfully');
                                        }).catch(err => {
                                            console.error('Mermaid render error:', err);
                                            container.innerHTML = '<div style="color: #DC2626; padding: 1rem;">Erro ao renderizar diagrama: ' + err.message + '</div>';
                                            preElement.appendChild(container);
                                        });
                                    } catch (err) {
                                        console.error('Mermaid exception:', err);
                                    }
                                }
                            }
                        });
                        
                        console.log('Total Mermaid diagrams found:', mermaidCount);
                    }, 2000);
                }
            });

            window.ui = ui;
        };
    </script>

